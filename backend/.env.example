# PropAI Command Center — Environment Variables

PORT=3001

# CORS — lock down to your frontend domain in production
ALLOWED_ORIGIN=http://localhost:5173

# ── CRM Integration ──────────────────────────────────────────────────────────
# HubSpot Free CRM (free forever at hubspot.com)
# 1. Sign up at https://app.hubspot.com/signup
# 2. Settings > Integrations > Private Apps > Create a private app
# 3. Enable scopes: crm.objects.contacts.read/write, crm.objects.deals.read/write, crm.objects.notes.read/write
# 4. Copy the access token below
HUBSPOT_ACCESS_TOKEN=

# ── Property Data APIs (optional — agents use mock data if not provided) ────
# RapidAPI Zillow: https://rapidapi.com/apimaker/api/zillow-com1
ZILLOW_API_KEY=
# Rentcast free tier (50 req/month): https://app.rentcast.io
RENTCAST_API_KEY=

# ── AI / LLM (optional — agents are rule-based by default) ─────────────────
# Anthropic Claude — for enhanced agent responses
ANTHROPIC_API_KEY=
